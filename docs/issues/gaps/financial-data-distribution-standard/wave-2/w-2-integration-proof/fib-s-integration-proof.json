    },
    "how": {
      "method": "real RPC and relay integration proof",
      "required_invariants": [
        "I1_atomicity",
        "I2_durability",
        "I3_idempotency",
        "I4_replayability"
      ],
      "proof_mechanisms": [
        "real database seeding",
        "real RPC invocation",
        "relay interruption simulation",
        "duplicate delivery simulation",
        "proof-state replay comparison",
        "runtime drift check"
      ]
    },
    "where": {
      "execution_contexts": [
        "local real Supabase/Postgres integration environment",
        "preview or deployed runtime if available"
      ],
      "excluded_contexts": [
        "production data",
        "external event broker",
        "external reconciliation system"
      ]
    },
    "who": {
      "primary_actor": "developer/operator",
      "secondary_actor": "Phase 2.1 implementer",
      "forbidden_actors": [
