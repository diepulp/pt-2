    "broad schema redesign"
  ],
  "entry_criteria": [
    "PRD-081 implementation available",
    "finance_outbox exists",
    "processed_messages exists",
    "rpc_claim_outbox_batch exists",
    "rpc_commit_consumer_receipt exists",
    "rpc_create_financial_txn emits outbox rows",
    "rpc_record_grind_observation emits outbox rows",
    "relay route exists",
    "test database can be reset safely"
  ],
  "exit_criteria": [
    "I1_atomicity_passes_for_both_exemplar_producers",
    "I2_durability_passes_under_relay_interruption",
    "I3_idempotency_passes_under_duplicate_delivery",
    "I4_replayability_passes_with_deterministic_state_comparison",
    "runtime_drift_findings_recorded",
    "WAVE-2-INTEGRATION-PROOF-SIGNOFF.md authored",
    "decision_is_either_phase_2_1_authorized_or_blocked"
  ],
  "governance": {
    "downstream_expansion_allowed_without_amendment": false,
    "phase_2_1_blocked_until_exit": true,
