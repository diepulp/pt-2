        "casino operator UI user",
        "reconciliation owner"
      ]
    },
    "when": {
      "entry_point": "after PRD-081 Phase 2.0 implementation",
      "exit_point": "before Phase 2.1 producer expansion",
      "blocking_relationship": "Phase 2.1 must not begin until this FIB exits successfully"
    },
    "why": {
      "reason": "Prevent Wave 2 producer expansion from building on an unproven transport substrate.",
      "risk_addressed": [
        "runtime drift",
        "false confidence from structural tests only",
        "orphaned authoring rows",
        "phantom outbox rows",
        "duplicate consumer side effects",
        "non-deterministic replay"
      ]
    }
  },
  "containment_loop": [
    "seed_real_integration_data",
    "invoke_rpc_create_financial_txn",
    "invoke_rpc_record_grind_observation",
    "drive_relay_path",
    "verify_processed_messages_idempotency",
    "capture_live_proof_state",
    "truncate_proof_state",
    "replay_from_finance_outbox",
    "compare_replay_to_live_state",
    "record_signoff"
  ],
  "required_outcomes": {
    "O1_real_rpc_execution": {
      "required": true,
      "mock_substitute_allowed": false,
      "producers": ["rpc_create_financial_txn", "rpc_record_grind_observation"]
    },
    "O2_atomicity": {
      "required": true,
      "assertions": [
        "authoring_row_and_outbox_row_commit_together",
        "failure_injection_rolls_back_both",
        "no_orphan_authoring_row",
        "no_phantom_outbox_row",
        "row_count_only_proof_rejected"
      ]
    },
    "O3_durability": {
      "required": true,
      "assertions": [
        "committed_outbox_row_survives_relay_failure",
        "row_remains_claimable_or_reclaimable",
        "later_processing_succeeds"
      ]
    },
    "O4_idempotency": {
      "required": true,
      "assertions": [
        "duplicate_event_id_yields_one_logical_side_effect",
        "processed_messages_receipt_commits_with_side_effect",
        "repeat_delivery_safe"
      ]
    },
    "O5_replayability": {
      "required": true,
      "assertions": [
        "live_processing_generates_deterministic_proof_state",
        "proof_state_can_be_truncated",
        "ordered_replay_rebuilds_equivalent_state",
        "live_and_replay_hashes_match"
      ]
    },
    "O6_runtime_drift_check": {
      "required": true,
      "areas": [
        "Supabase RPC execution",
        "service_role_relay_access",
        "cron_secret_validation",
        "RLS behavior",
        "environment_variables"
      ]
    },
    "O7_evidence_artifact": {
      "required": true,
      "artifact_name": "WAVE-2-INTEGRATION-PROOF-SIGNOFF.md",
      "minimum_fields": [
        "environment_tested",
        "commands_or_scripts_run",
        "I1_result",
        "I2_result",
        "I3_result",
        "I4_result",
        "runtime_drift_findings",
        "decision"
      ]
    }
  },
  "explicit_exclusions": [
    "rpc_create_financial_adjustment producer wiring",
    "rpc_request_table_fill producer wiring",
    "rpc_request_table_credit producer wiring",
    "new projection stores (exception: outbox_integration_proof_state is authorized as a test harness artifact for I4 replay hashing; not a projection store, not a product read model, must not be consumed by application code outside PRD-082 validation)",
    "lifecycle-aware completeness projection",
    "shift telemetry projection",
    "dashboard freshness behavior",
    "operator-visible UI changes",
    "replay UI",
